// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SavedBrief {
  id           String   @id @default(cuid())
  shop         String
  productId    String
  productTitle String
  angle        String
  payloadJson  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, productId])
}

model VideoAnalysis {
  id           String   @id @default(cuid())
  shop         String
  productId    String
  productTitle String
  fileName     String?
  brief        String?
  payloadJson  String
  savedToLibrary Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, productId])
}

model SavedCreative {
  id           String   @id @default(cuid())
  shop         String
  sourceType   String
  sourceId     String?
  productId    String
  productTitle String
  title        String
  angle        String?
  payloadJson  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, productId])
}

model RevenueBlueprint {
  id          String   @id @default(cuid())
  shop        String
  payloadJson String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop, createdAt])
}

model WorkspaceRequest {
  id          String   @id @default(cuid())
  shop        String
  type        String
  status      String   @default("requested")
  payloadJson String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, type])
}

model WorkspaceSetting {
  id        String   @id @default(cuid())
  shop      String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
}
