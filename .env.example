# Shopify app (required)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
# Required in production: exact deployed HTTPS origin, with no trailing slash.
SHOPIFY_APP_URL=
SCOPES=read_products

# Production PostgreSQL (required in production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/blueprintai?sslmode=require

# Private S3-compatible media storage (required in production)
FILE_STORAGE_DRIVER=s3
# Maximum allowed size for each creative/video upload (default: 104857600 / 100 MB)
MAX_UPLOAD_SIZE_BYTES=104857600
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional for non-AWS S3-compatible storage:
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# AI Review Studio analyzer (all three settings are required for analysis)
ANALYZER_ENABLED=false # Safe default: uploads are stored, but analysis does not run
ANALYZER_SERVICE_URL=https://analyzer.example.com/v1/analyze # HTTPS analyzer endpoint
ANALYZER_API_KEY=replace-with-analyzer-api-key # Secret sent as a Bearer token; never commit a real key
ANALYZER_TIMEOUT_MS=60000 # Entire analyzer request deadline in milliseconds

# Development only. Production code ignores this setting.
DEV_BYPASS_SHOPIFY_AUTH=false

# Current review listing is free.
SHOPIFY_BILLING_REQUIRED=false
SHOPIFY_BILLING_BYPASS=false

# Production database
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
